<?xml version="1.0" encoding="utf-8" ?>
<widget id="isracard.widgets.twiliovideochat.TwilioVideoChat" pluginWidget="true" needsEntityContext="false" offlineCapable="false"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Isracard Twilio Video Chat</name>
    <description>Mendix widget for Twilio Video chats - Isracard modification</description>
    <studioProCategory>Isracard Widgets</studioProCategory>
    <icon>
        
    </icon>
    <properties>
        <propertyGroup caption="Room joining">
            <property key="roomNameExpr" type="expression">
                <caption>Room name</caption>
                <description>String expression</description>
                <returnType type="String" />
            </property>
            <property key="nickNameExpr" type="expression">
                <caption>Nick name</caption>
                <description>String expression</description>
                <returnType type="String" />
            </property>
            <property key="joinRoomActiveExpr" type="expression">
                <caption>Join room</caption>
                <description>Boolean expression</description>
                <returnType type="Boolean" />
            </property>
            <property key="cameraEnabledExpr" type="expression" required="false">
                <caption>Camera available</caption>
                <description>When false, local video track will not be created when joining the room.</description>
                <returnType type="Boolean" />
            </property>

            <property key="microphoneEnabledExpr" type="expression" required="false">
                <caption>Microphone available</caption>
                <description>When false, local audio track will not be created when joining the room.</description>
                <returnType type="Boolean" />
            </property>
        </propertyGroup>
        <propertyGroup caption="Authentication">
            <property key="accessTokenExpr" type="expression" required="true">
                <caption>Access Token</caption>
                <description>Access Token. You can generate using our helper Java Action:
                GenerateAccessToken in TwilioAccessTokenGenerator module.</description>
                <returnType type="String" />
            </property>
        </propertyGroup>
        <propertyGroup caption="Camera preview">
            <property key="previewActiveExpr" type="expression">
                <caption>Show camera preview</caption>
                <description>Boolean expression</description>
                <returnType type="Boolean" />
            </property>
            <property key="previewSelector" type="string" required="false">
                <caption>Camera preview selector</caption>
                <description>Optional CSS selector. If not empty, will redirect local camera preview into this element.
                Otherwise, will render it into this widget content (div.local-media).</description>
            </property>
        </propertyGroup>
        <propertyGroup caption="Events">
            <property key="onConnectedAction" type="action" required="false">
                <caption>On connected</caption>
                <description>Executed after successfully joining the Twilio room.</description>
            </property>

            <property key="onDisconnectedAction" type="action" required="false">
                <caption>On disconnected</caption>
                <description>Executed after leaving the Twilio room.</description>
            </property>

            <property key="onErrorAction" type="action" required="false">
                <caption>On error</caption>
                <description>Executed when a Twilio connection or media error occurs.</description>
            </property>
        </propertyGroup>
        <propertyGroup caption="Logging">
            <property key="logActiveExpr" type="expression">
                <caption>Logging is active</caption>
                <description>Boolean expression</description>
                <returnType type="Boolean" />
            </property>
            <property key="logSelector" type="string" required="false">
                <caption>Log selector</caption>
                <description>Optional CSS selector. If not empty, will log messages into this element.
                Otherwise, will render it into this widget content (div.log).</description>
            </property>
        </propertyGroup>
    </properties>
</widget>
